# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend (transactional email)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# From address used for all transactional email (must be on a domain you've verified with Resend)
EMAIL_FROM=noreply@updates.nwnewswire.com

# Platform admin email (receives org registration notifications)
PLATFORM_ADMIN_EMAIL=admin@yourplatform.com

# Admin dashboard HTTP basic auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-use-strong-password

# Secret used to sign HMAC admin approve/reject email links.
# Must be set in production; signAdminToken/verifyAdminToken will throw if missing.
ADMIN_TOKEN_SECRET=changeme-use-a-long-random-string

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Story alert digest hour (0-23, default 7 = 7am)
ALERT_DIGEST_HOUR=7

# Secret token for cron job authentication (any random string; Vercel Cron sends this as Bearer token)
CRON_SECRET=your-cron-secret
